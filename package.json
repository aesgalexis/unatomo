{
  "name": "unatomo",
  "version": "1.0.0",
  "description": "Machine-centered operational dashboard with QR/NFC access, history, tasks, documents, and Firebase backend.",
  "main": "index.js",
  "scripts": {
    "predev": "node scripts/generate-config.mjs",
    "predev:static": "node scripts/generate-config.mjs",
    "prebuild": "node scripts/generate-config.mjs",
    "dev": "vite",
    "dev:static": "node scripts/dev-server.mjs",
    "build": "node scripts/build-static.mjs",
    "preview": "vite preview",
    "site:publish": "node scripts/site-publish.mjs",
    "lint:links": "node scripts/lint-links.mjs",
    "scan:secrets": "node scripts/scan-secrets.mjs",
    "doctor": "node scripts/doctor.mjs",
    "firebase:clean": "node scripts/firebase-clean.mjs",
    "deploy:nfc:firestore": "node scripts/firebase-clean.mjs deploy --only firestore",
    "deploy:nfc:storage": "node scripts/firebase-clean.mjs deploy --only storage",
    "deploy:nfc:functions": "node scripts/firebase-clean.mjs deploy --only functions",
    "deploy:nfc:backend": "node scripts/firebase-clean.mjs deploy --only functions,firestore",
    "backup:nfc:firestore": "node scripts/backup-firestore-nfc.mjs",
    "backup:nfc:storage": "node scripts/backup-storage-inventory-nfc.mjs",
    "backup:nfc:auth": "node scripts/backup-auth-nfc.mjs",
    "backup:nfc:all": "node scripts/backup-nfc-all.mjs",
    "check:nfc:layout": "node scripts/validate-dashboard-layout-backup.mjs",
    "check:nfc:group-hierarchy": "node scripts/test-dashboard-group-hierarchy.mjs",
    "check:nfc:sorting": "node scripts/test-dashboard-sorting.mjs",
    "check:nfc:autosave": "node scripts/test-dashboard-autosave.mjs",
    "check:nfc:status-incident": "node scripts/test-dashboard-status-incident.mjs",
    "check:nfc:architecture": "node scripts/check-nfc-architecture.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aesgalexis/unatomo.git"
  },
  "keywords": [
    "machines",
    "nfc",
    "qr",
    "dashboard",
    "firebase",
    "maintenance"
  ],
  "author": "Alexis Santana",
  "license": "UNLICENSED",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/aesgalexis/unatomo/issues"
  },
  "homepage": "https://github.com/aesgalexis/unatomo#readme",
  "devDependencies": {
    "vite": "^7.3.1"
  },
  "volta": {
    "node": "22.12.0",
    "npm": "11.0.0"
  }
}
