rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isLaundryServicesAdmin() {
      return isSignedIn()
        && request.auth.token.laundryServicesAdmin == true;
    }

    function isLaundryMachineImage() {
      return request.resource != null
        && request.resource.size <= 12 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }

    function acceptedAdminLink(machineId) {
      return /databases/(default)/documents/admin_machine_links/$(machineId + "_" + request.auth.uid);
    }

    function isAcceptedAdminOfMachine(ownerUid, machineId) {
      return isSignedIn()
        && firestore.exists(acceptedAdminLink(machineId))
        && firestore.get(acceptedAdminLink(machineId)).data.adminUid == request.auth.uid
        && firestore.get(acceptedAdminLink(machineId)).data.ownerUid == ownerUid
        && firestore.get(acceptedAdminLink(machineId)).data.status == "accepted";
    }

    function canManageMachine(ownerUid, machineId) {
      return isSignedIn()
        && (request.auth.uid == ownerUid || isAcceptedAdminOfMachine(ownerUid, machineId));
    }

    function isPlateImage() {
      return request.resource != null
        && request.resource.size <= 12 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }

    function isManualPdf() {
      return request.resource != null
        && request.resource.size <= 25 * 1024 * 1024
        && request.resource.contentType == 'application/pdf';
    }

    function isOtherDocument() {
      return request.resource != null
        && request.resource.size <= 25 * 1024 * 1024
        && (
          request.resource.contentType == 'application/pdf'
          || request.resource.contentType.matches('image/(jpeg|png|webp)')
        );
    }

    match /machine-docs/{ownerUid}/{machineId}/plate/{fileName} {
      allow read: if canManageMachine(ownerUid, machineId);
      allow create, update: if canManageMachine(ownerUid, machineId) && isPlateImage();
      allow delete: if canManageMachine(ownerUid, machineId);
    }

    match /machine-docs/{ownerUid}/{machineId}/manual/{fileName} {
      allow read: if canManageMachine(ownerUid, machineId);
      allow create, update: if canManageMachine(ownerUid, machineId) && isManualPdf();
      allow delete: if canManageMachine(ownerUid, machineId);
    }

    match /machine-docs/{ownerUid}/{machineId}/other/{fileName} {
      allow read: if canManageMachine(ownerUid, machineId);
      allow create, update: if canManageMachine(ownerUid, machineId) && isOtherDocument();
      allow delete: if canManageMachine(ownerUid, machineId);
    }

    match /maquinaria/{machineId}/{fileName} {
      allow read: if true;
      allow create, update: if isLaundryServicesAdmin() && isLaundryMachineImage();
      allow delete: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
